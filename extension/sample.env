# Do not commit this file to source control - it contains sensitive secrets.
# Copy to ".env" and fill in. See README.md "Quick Start".
EXPERIENCE_EXTENSION_UPLOAD_TOKEN=<upload-token>

# Optional setup-api variables - uncomment and fill out to auto-configure on upload:
# EXPERIENCE_EXTENSION_ENABLED=<true/false>
# EXPERIENCE_EXTENSION_ENVIRONMENTS=<Tenant1,Tenant2>

# Card Config - Data Connect pipeline names (Banner)
PIPELINE_GET_TEXAS_GRANT_ATTESTATION=ethos-example-get-texas-grant-attestation
PIPELINE_POST_TEXAS_GRANT_ATTESTATION=ethos-example-post-texas-grant-attestation

# ---------------------------------------------------------------------------
# Local offline mock (no Ethos / no Data Connect needed). Set USE_MOCK_DATA=true
# and run `npm start` to build and demo the card UI locally. Leave it unset/false
# for real builds that talk to Banner.
# USE_MOCK_DATA=true
# Optional seeds to demo each card state:
#   MOCK_ELIGIBLE=false           -> ineligible student (card renders nothing)
#   MOCK_CURRENT_ANSWER=yes        -> start with a recorded "yes" response
#   MOCK_CURRENT_ANSWER=no         -> start with a recorded "no" response
#   MOCK_AID_YEAR=2526
# USE_MOCK_DATA=true
# MOCK_ELIGIBLE=true
# MOCK_CURRENT_ANSWER=
