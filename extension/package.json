{
  "name": "texas-grant-attestation-extension",
  "version": "1.0.0",
  "description": "Texas Grant felony / controlled-substance attestation card. Available to students awarded a Texas grant; records the answer to Banner RRAAREQ via the applicant_requirements Business API.",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "npx eslint --ext .jsx,.js src",
    "build-dev": "webpack --progress --mode development --env verbose",
    "build-prod": "webpack --progress --mode production --env verbose",
    "deploy-dev": "webpack --progress --mode development --env verbose --env upload",
    "deploy-dev-force": "webpack --progress --mode development --env verbose --env upload --env forceUpload",
    "deploy-prod": "webpack --progress --mode production --env verbose --env upload",
    "watch-and-upload": "webpack --hot --watch --mode development --env verbose --env upload --env forceUpload",
    "start": "webpack serve --mode development --env verbose --env liveReload",
    "build-standalone": "webpack --config webpack.standalone.js"
  },
  "dependencies": {
    "@ellucian/ds-icons": "https://cdn.elluciancloud.com/assets/EDS2/8.2.2/umd/path_design_system_icons.tgz",
    "@ellucian/experience-extension-extras": "github:ellucian-developer/experience-extension-extras#8.0.0",
    "@ellucian/experience-extension-utils": "https://cdn.elluciancloud.com/assets/SDK/utils/1.0.0/ellucian-experience-extension-utils-1.0.0.tgz",
    "@ellucian/react-design-system": "https://cdn.elluciancloud.com/assets/EDS2/8.2.2/umd/path_design_system.tgz",
    "classnames": "^2.3.2",
    "dotenv-webpack": "^7.1.1",
    "jwt-decode": "3.1.2",
    "loglevel": "^1.8.1",
    "prop-types": "15.7.2",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "react-intl": "7.1.11",
    "react-router-dom": "5.2.0"
  },
  "devDependencies": {
    "@babel/core": "7.12.3",
    "@babel/plugin-transform-runtime": "7.12.1",
    "@babel/preset-env": "7.12.1",
    "@babel/preset-react": "7.12.1",
    "@ellucian/experience-extension": "https://cdn.elluciancloud.com/assets/SDK/8.0.1/ellucian-experience-extension-8.0.1.tgz",
    "babel-plugin-rewire": "1.2.0",
    "cross-env": "7.0.2",
    "dotenv": "8.2.0",
    "@eslint/js": "9.33.0",
    "eslint": "9.33.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "webpack": "5.99.9",
    "webpack-cli": "4.10.0",
    "webpack-dev-server": "4.15.2"
  },
  "overrides": {
    "@ellucian/react-design-system": {
      "@tanstack/react-virtual": "3.11.3"
    }
  }
}
